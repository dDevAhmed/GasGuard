{
  "name": "@gasguard/templates-stellar",
  "version": "0.1.0",
  "description": "Secure Soroban contract starter templates and generator for GasGuard",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:cov": "jest --coverage",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "soroban",
    "stellar",
    "smart-contracts",
    "templates",
    "gasguard"
  ],
  "author": "GasGuard Team",
  "license": "MIT",
  "dependencies": {
    "fs-extra": "^11.1.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.spec.ts"
    ],
    "coverageDirectory": "coverage"
  }
}
